{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athenatheowl.github.io/grid-silicon/schemas/realness-score.schema.json",
  "title": "GridSilicon realness score row",
  "type": "object",
  "required": [
    "month",
    "iso",
    "project_id",
    "project_name",
    "county",
    "mw_announced",
    "mw_observed_energized",
    "phantom_mw",
    "realness_score",
    "status_code",
    "source_mode",
    "evidence_ids",
    "evidence",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "month": {"type": "string", "pattern": "^\\d{4}-\\d{2}$"},
    "iso": {"type": "string", "enum": ["ercot"]},
    "project_id": {"type": "string"},
    "project_name": {"type": "string"},
    "county": {"type": "string"},
    "mw_announced": {"type": "number", "minimum": 0},
    "mw_observed_energized": {"type": "number", "minimum": 0},
    "phantom_mw": {"type": "number", "minimum": 0},
    "realness_score": {"type": "integer", "minimum": 0, "maximum": 100},
    "status_code": {"type": "string"},
    "source_mode": {"type": "string", "enum": ["fixture", "live"]},
    "evidence_ids": {"type": "array", "minItems": 5, "items": {"type": "string"}},
    "evidence": {"type": "array", "minItems": 5, "items": {"$ref": "evidence-item.schema.json"}},
    "notes": {"type": "string"}
  }
}
